{
  "manifest_version": 3,
  "name": "Chess.com Coordinates",
  "version": "1.0",
  "description": "Displays chess square coordinates on chess.com with hover effect",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "js": ["js/content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Chess.com Coordinates",
    "default_popup": "popup.html"
  }
}
